Subject: [PATCH] add debug outputs

---
 makepanda/makepandacore.py | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/makepanda/makepandacore.py b/makepanda/makepandacore.py
index 5e7fd98f38..ee609d416e 100644
--- a/makepanda/makepandacore.py
+++ b/makepanda/makepandacore.py
@@ -2508,7 +2508,10 @@ def SdkLocateMacOSX(osxtarget = None, archs = []):
         else:
             sdkname = "MacOSX%d.%d" % osxtarget
 
-        sdk_root_conda_build = os.environ.get('OSX_SDK_DIR')
+        sdk_root_conda_build = os.environ.get('PANDA3D_OSX_SDK_DIR')
+        print("============== sdk_root_conda_build = ", sdk_root_conda_build)
+        print("============== sdkname = ", sdkname)
+        print("============== osxtarget = ", osxtarget)
         if sdk_root_conda_build:
             SDK["MACOSX"] = "%s/%s.sdk" % (sdk_root_conda_build, sdkname)
             print("============== SDK[MACOSX]=", SDK["MACOSX"])
